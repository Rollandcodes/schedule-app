{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "declaration": true,
    "resolveJsonModule": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@schedule/prisma/client": [
        "../../../packages/prisma/generated/prisma/client"
      ],
      "@schedule/prisma/enums": [
        "../../../packages/prisma/enums"
      ],
      "@schedule/platform-constants": [
        "../../../packages/platform/constants/index.ts"
      ],
      "@schedule/platform-types": [
        "../../../packages/platform/types/index.ts"
      ],
      "@schedule/platform-utils": [
        "../../../packages/platform/utils/index.ts"
      ],
      "@schedule/platform-enums": [
        "../../../packages/platform/enums/index.ts"
      ],
      "@schedule/platform-libraries/event-types": [
        "../../../packages/platform/libraries/event-types.ts"
      ],
      "@schedule/platform-libraries/slots": [
        "../../../packages/platform/libraries/slots.ts"
      ],
      "@schedule/platform-libraries/emails": [
        "../../../packages/platform/libraries/emails.ts"
      ],
      "@schedule/platform-libraries/schedules": [
        "../../../packages/platform/libraries/schedules.ts"
      ],
      "@schedule/platform-libraries/app-store": [
        "../../../packages/platform/libraries/app-store.ts"
      ],
      "@schedule/platform-libraries/conferencing": [
        "../../../packages/platform/libraries/conferencing.ts"
      ],
      "@schedule/platform-libraries/repositories": [
        "../../../packages/platform/libraries/repositories.ts"
      ],
      "@schedule/platform-libraries/bookings": [
        "../../../packages/platform/libraries/bookings.ts"
      ],
      "@schedule/platform-libraries/private-links": [
        "../../../packages/platform/libraries/private-links.ts"
      ],
      "@schedule/platform-libraries/organizations": [
        "../../../packages/platform/libraries/organizations.ts"
      ],
      "@schedule/platform-libraries/errors": [
        "../../../packages/platform/libraries/errors.ts"
      ],
      "@schedule/platform-libraries/calendars": [
        "../../../packages/platform/libraries/calendars.ts"
      ],
      "@schedule/platform-libraries/tasker": [
        "../../../packages/platform/libraries/tasker.ts"
      ],
      "@schedule/platform-libraries/pbac": [
        "../../../packages/platform/libraries/pbac.ts"
      ]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false
  },
  "watchOptions": {
    "watchFile": "fixedPollingInterval",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "synchronousWatchDirectory": true,
    "excludeDirectories": [
      "**/node_modules",
      "dist"
    ]
  },
  "exclude": [
    "./dist",
    "./node_modules",
    "next-i18next.config.js"
  ],
  "include": [
    "./**/*.ts",
    "../../../packages/types/*.d.ts"
  ]
}
